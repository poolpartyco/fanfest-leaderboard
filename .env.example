# Frontend (Vite) — shipped to the browser, so anon key only.
VITE_SUPABASE_URL=https://your-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Poller / seed — SERVER-SIDE ONLY. Never prefix these with VITE_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
HIGHLIGHTLY_API_KEY=your-highlightly-api-key

# Used by the Supabase CLI for hosted migrations.
SUPABASE_PROJECT_REF=your-ref
SUPABASE_DB_PASSWORD=your-db-password
